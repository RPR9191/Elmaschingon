# ── Supabase (requerido para guardar pedidos) ──
NEXT_PUBLIC_SUPABASE_URL=tu_url_de_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# ── Resend (gratuito, para notificaciones por email) ──
# 1. Regístrate gratis en https://resend.com
# 2. Crea una API Key en el dashboard
# 3. Verifica el dominio o usa onboarding@resend.dev (sandbox)
# 4. Copia la API Key aquí:
# RESEND_API_KEY=re_xxxxxxxxxxxx
#
# Sin esta variable, el email se omite silenciosamente.
# Los pedidos y notificaciones al admin siguen funcionando.
RESEND_API_KEY=